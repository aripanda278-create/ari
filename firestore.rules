rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function owner() { return signedIn() && request.auth.token.email == 'aripanda278@gmail.com'; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function admin() { return owner() || (signedIn() && userDoc().data.role == 'admin'); }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid
        && (request.resource.data.role == 'member' || owner());
      allow update: if owner() || (signedIn() && request.auth.uid == uid
        && request.resource.data.role == resource.data.role);
      allow delete: if owner();
    }
    match /presence/{uid} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == uid;
    }
    match /reservations/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid
        && (admin() || request.resource.data.status == 'planned');
      allow update, delete: if admin() || (signedIn() && resource.data.ownerUid == request.auth.uid && resource.data.status == 'planned');
    }
    match /diplomacy/{id} { allow read: if signedIn(); allow write: if admin(); }
    match /operations/{id} { allow read: if signedIn(); allow write: if admin(); }
    match /activity/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if owner();
    }
    match /{document=**} { allow read, write: if false; }
  }
}
